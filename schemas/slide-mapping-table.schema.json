{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://presentationos.dev/schemas/slide-mapping-table.schema.json",
  "title": "PresentationOS Slide Mapping Table",
  "description": "Machine-readable build contract for a PresentationOS deck.",
  "type": "object",
  "additionalProperties": false,
  "required": ["project_id", "artifact_version", "status", "slides"],
  "properties": {
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["DRAFT", "REVIEW_REQUIRED", "APPROVED", "SUPERSEDED"]
    },
    "language": {
      "type": "string"
    },
    "target_slide_count": {
      "type": ["integer", "null"],
      "minimum": 1
    },
    "assumptions": {
      "type": "array",
      "items": {"type": "string"}
    },
    "open_questions": {
      "type": "array",
      "items": {"type": "string"}
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/slide"}
    }
  },
  "$defs": {
    "sourceReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "location"],
      "properties": {
        "file": {"type": "string", "minLength": 1},
        "location": {"type": "string", "minLength": 1},
        "supports": {"type": "string"},
        "notes": {"type": "string"}
      }
    },
    "visual": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "purpose"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "none",
            "text-led",
            "photo",
            "illustration",
            "icon-system",
            "chart",
            "table",
            "diagram",
            "process",
            "timeline",
            "comparison",
            "map",
            "screenshot",
            "mixed",
            "other"
          ]
        },
        "purpose": {"type": "string", "minLength": 1},
        "specification_id": {"type": ["string", "null"]},
        "notes": {"type": "array", "items": {"type": "string"}}
      }
    },
    "asset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["asset_id", "type", "status"],
      "properties": {
        "asset_id": {"type": "string", "minLength": 1},
        "type": {"type": "string"},
        "filename": {"type": ["string", "null"]},
        "status": {
          "type": "string",
          "enum": ["AVAILABLE", "TO_SOURCE", "TO_GENERATE", "RIGHTS_REVIEW", "BLOCKED"]
        },
        "notes": {"type": "string"}
      }
    },
    "slide": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slide_number",
        "section",
        "slide_type",
        "slide_objective",
        "action_title",
        "key_message",
        "supporting_points",
        "sources",
        "visual",
        "layout_family",
        "assets",
        "build_notes",
        "open_issues",
        "status"
      ],
      "properties": {
        "slide_number": {"type": "integer", "minimum": 1},
        "section": {"type": "string", "minLength": 1},
        "slide_type": {
          "type": "string",
          "enum": [
            "cover",
            "agenda",
            "divider",
            "statement",
            "data",
            "comparison",
            "process",
            "timeline",
            "portfolio",
            "case-study",
            "closing",
            "appendix",
            "other"
          ]
        },
        "slide_objective": {"type": "string", "minLength": 1},
        "action_title": {"type": "string", "minLength": 1},
        "key_message": {"type": "string", "minLength": 1},
        "supporting_points": {
          "type": "array",
          "maxItems": 5,
          "items": {"type": "string", "minLength": 1}
        },
        "evidence": {
          "type": "array",
          "items": {"type": "string"}
        },
        "sources": {
          "type": "array",
          "items": {"$ref": "#/$defs/sourceReference"}
        },
        "visual": {"$ref": "#/$defs/visual"},
        "layout_family": {"type": "string", "minLength": 1},
        "assets": {
          "type": "array",
          "items": {"$ref": "#/$defs/asset"}
        },
        "copy_limits": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "title_max_lines": {"type": ["integer", "null"], "minimum": 1},
            "body_max_words": {"type": ["integer", "null"], "minimum": 1},
            "notes": {"type": "string"}
          }
        },
        "build_notes": {
          "type": "array",
          "items": {"type": "string"}
        },
        "speaker_notes_or_appendix_link": {
          "type": ["string", "null"]
        },
        "open_issues": {
          "type": "array",
          "items": {"type": "string"}
        },
        "status": {
          "type": "string",
          "enum": ["DRAFT", "REVIEW_REQUIRED", "APPROVED", "DEFERRED"]
        }
      }
    }
  }
}
